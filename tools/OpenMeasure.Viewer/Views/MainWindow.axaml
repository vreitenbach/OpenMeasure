<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:OpenMeasure.Viewer.ViewModels"
        xmlns:m="using:OpenMeasure.Viewer.Models"
        xmlns:sp="clr-namespace:ScottPlot.Avalonia;assembly=ScottPlot.Avalonia"
        x:Class="OpenMeasure.Viewer.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{Binding Title}"
        Width="1280" Height="800"
        DragDrop.AllowDrop="True"
        WindowStartupLocation="CenterScreen">

    <Window.Styles>
        <Style Selector="TextBlock.header">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="8,8,8,4" />
        </Style>
        <Style Selector="TextBlock.mono">
            <Setter Property="FontFamily" Value="Cascadia Code, Consolas, Courier New, monospace" />
            <Setter Property="FontSize" Value="12" />
        </Style>
    </Window.Styles>

    <DockPanel>
        <!-- Menu Bar -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_Open..." Name="MenuOpen" />
                <MenuItem Header="_Close" Command="{Binding CloseFileCommand}" />
                <Separator />
                <MenuItem Header="E_xit" Name="MenuExit" />
            </MenuItem>
        </Menu>

        <!-- Status Bar -->
        <Border DockPanel.Dock="Bottom" Background="#F0F0F0" Padding="8,4">
            <TextBlock Text="{Binding StatusText}" FontSize="12" />
        </Border>

        <!-- Main Content -->
        <Grid ColumnDefinitions="280,1,*">

            <!-- Left: Tree + File Info -->
            <DockPanel Grid.Column="0" Background="#FAFAFA">

                <!-- File Info -->
                <Border DockPanel.Dock="Bottom" Padding="8" BorderThickness="0,1,0,0"
                        BorderBrush="#E0E0E0" IsVisible="{Binding IsFileOpen}">
                    <TextBlock Text="{Binding FileInfo}" Classes="mono" FontSize="11"
                               TextWrapping="Wrap" />
                </Border>

                <!-- Channel Tree -->
                <TreeView ItemsSource="{Binding TreeNodes}"
                          SelectedItem="{Binding SelectedNode}"
                          Margin="4">
                    <TreeView.ItemTemplate>
                        <TreeDataTemplate ItemsSource="{Binding Children}" x:DataType="m:ChannelTreeNode">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="{Binding Icon}" FontSize="14" />
                                <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center" />
                            </StackPanel>
                        </TreeDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>
            </DockPanel>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="4" Background="#E0E0E0" />

            <!-- Right: Tab content -->
            <TabControl Grid.Column="2" Margin="4">

                <!-- Plot Tab -->
                <TabItem Header="Plot" IsVisible="{Binding HasPlot}">
                    <sp:AvaPlot Name="MainPlot" />
                </TabItem>

                <!-- Statistics Tab -->
                <TabItem Header="Statistics" IsVisible="{Binding HasStatistics}">
                    <ScrollViewer Padding="16">
                        <StackPanel Spacing="8">
                            <TextBlock Classes="header" Text="Channel Statistics" />
                            <TextBlock Text="{Binding StatisticsText}" Classes="mono"
                                       FontSize="14" LineHeight="24" />
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- Frames Tab -->
                <TabItem Header="Frames" IsVisible="{Binding HasFrames}">
                    <DataGrid ItemsSource="{Binding FrameRows}"
                              IsReadOnly="True"
                              GridLinesVisibility="Horizontal"
                              CanUserReorderColumns="True"
                              CanUserResizeColumns="True"
                              CanUserSortColumns="True"
                              FontSize="12"
                              FontFamily="Cascadia Code, Consolas, Courier New, monospace">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="#" Binding="{Binding Index}" Width="60" />
                            <DataGridTextColumn Header="Time" Binding="{Binding Timestamp}" Width="140" />
                            <DataGridTextColumn Header="ID" Binding="{Binding FrameId}" Width="80" />
                            <DataGridTextColumn Header="DLC" Binding="{Binding Dlc}" Width="50" />
                            <DataGridTextColumn Header="Frame" Binding="{Binding FrameName}" Width="120" />
                            <DataGridTextColumn Header="Payload (Hex)" Binding="{Binding PayloadHex}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>

                <!-- Signals Tab -->
                <TabItem Header="Signals" IsVisible="{Binding HasSignals}">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="8">
                            <TextBlock Text="Select signal to plot:" VerticalAlignment="Center" />
                            <ComboBox ItemsSource="{Binding SignalNames}"
                                      SelectedItem="{Binding SelectedSignal}"
                                      Width="300" />
                        </StackPanel>
                        <sp:AvaPlot Name="SignalPlot" IsVisible="{Binding HasPlot}" />
                    </DockPanel>
                </TabItem>

                <!-- Welcome / Drop Zone -->
                <TabItem Header="Welcome" IsVisible="{Binding !IsFileOpen}">
                    <Border Background="#F8F8F8" CornerRadius="8" Margin="20"
                            BorderBrush="#D0D0D0" BorderThickness="2"
                            Padding="40">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16">
                            <TextBlock Text="OpenMeasure Viewer" FontSize="28" FontWeight="Light"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="Drop an .omx file here or use File > Open"
                                       FontSize="16" Foreground="#888"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </TabItem>

            </TabControl>
        </Grid>
    </DockPanel>
</Window>
